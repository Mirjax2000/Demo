# ── Django ──────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-50-char-string
DJANGO_ENV=development
# DJANGO_ENV=production

# ── Allowed hosts (comma-separated) ────────────────────
ALLOWED_HOSTS=127.0.0.1,localhost

# ── HTTPS (production) ─────────────────────────────────
USE_HTTPS=False

# ── Field encryption (GDPR) ────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=

# ── System users (created by populate_db command) ──────
SYSTEM_SUPER_USER=admin
SYSTEM_SUPER_USER_PASS=change-me

SYSTEM_USER=dispatcher
SYSTEM_USER_PASS=change-me

SYSTEM_BOT=bot
SYSTEM_BOT_PASS=change-me

# ── Bot settings ───────────────────────────────────────
BOT_URL=https://your-domain.cz
BOT_GLS_LOGIN=
BOT_GLS_PASS=
BOT_BROWSER_PATH=

# ── Database (optional — defaults to SQLite) ───────────
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=ams
# DB_USER=ams
# DB_PASSWORD=change-me
# DB_HOST=localhost
# DB_PORT=5432
